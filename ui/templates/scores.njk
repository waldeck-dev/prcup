{% import("ui/templates/ranking.njk") as ranking %}
{% extends "ui/templates/main.html" %}
{% block content %}
<div class="container">
  <h1 class="is-size-1 has-text-centered">#PRCup</h1>
  {% if nextTarget %}<h2 class="is-size-4 has-text-centered">NEXT : <strong>#{{ nextTarget }}</strong></h2>{% endif %}
  {% if availableYears and availableYears | length > 0 %}
  <div class="field mt-5 mb-5 is-flex is-justify-content-center is-align-items-center">
    <label class="label mr-3 mb-0" for="year-selector">Year</label>
    <div class="control">
      <div class="select">
        <select id="year-selector">
          {% for year in availableYears %}
          <option value="{{ year }}" {% if year == selectedYear %}selected{% endif %}>{{ year }}</option>
          {% endfor %}
        </select>
      </div>
    </div>
  </div>
  {% endif %}

  {% for yearData in rankedScoresByYear %}
  <div class="year-panel{% if yearData.year != selectedYear %} is-hidden{% endif %}" data-year="{{ yearData.year }}">
    {% if yearData.hasActiveScores %}
    {{ ranking.genranking(yearData.rankedScoresActive) }}
    {% endif %}

    {% if not yearData.hasActiveScores and not yearData.hasInactiveScores %}
    <p class="has-text-centered mt-6 mb-6">No closed items for {{ yearData.year }} yet.</p>
    {% endif %}

    {% if yearData.hasInactiveScores %}
    <div class="collapsible mt-6 has-text-centered">
      <button class="button is-text" type="button" onclick="this.nextElementSibling.classList.toggle('is-hidden')">
        Former Competitors
      </button>
      <div class="mt-3 is-hidden">
        {{ ranking.genranking(yearData.rankedScoresInactive) }}
      </div>
    </div>
    {% endif %}
  </div>
  {% endfor %}
</div>

<script>
  (function () {
    const selector = document.getElementById("year-selector");

    if (!selector) {
      return;
    }

    const panels = Array.from(document.querySelectorAll(".year-panel"));

    const togglePanel = (year) => {
      for (const panel of panels) {
        panel.classList.toggle("is-hidden", panel.dataset.year !== year);
      }
    };

    selector.addEventListener("change", (event) => {
      togglePanel(event.target.value);
    });

    togglePanel(selector.value);
  })();
</script>
{% endblock %}